[node name="RulesTextLabel" type="Label" parent="HUDLayer/RulesModal/Panel/ScrollContainer" unique_id=1500724357]
custom_minimum_size = Vector2(792, 0)
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "Objective
Be the first player to empty your hand after calling TAP at the right time.

Active Card
The face-up card in the centre controls what can be played next.

Valid Match
Your first card must match the Active Card by rank OR suit.

Match + Discard
After a valid match, you may discard one extra card. The final card played becomes the new Active Card.

Optional Chain
You may play an ordered chain where each card matches the previous card by rank OR suit.

TAP Rule
Call TAP before the turn where you go out. TAP is armed for your next turn only.

Passing / Draw
If you cannot match the Active Card, pass. If everyone passes, each player draws one card."
autowrap_mode = 2

